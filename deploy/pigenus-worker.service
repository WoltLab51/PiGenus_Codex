[Unit]
Description=PiGenus local maintenance worker
After=pigenus.service
Wants=pigenus.service

[Service]
Type=simple
User=pigenus
Group=pigenus
WorkingDirectory=/opt/pigenus
EnvironmentFile=/etc/pigenus/pigenus.env
ExecStart=/opt/pigenus/.venv/bin/pigenus-worker
Restart=on-failure
RestartSec=5
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=full
ProtectHome=true
ReadWritePaths=/var/lib/pigenus /var/log/pigenus
RuntimeDirectory=pigenus-worker
StateDirectory=pigenus
LogsDirectory=pigenus

[Install]
WantedBy=multi-user.target
