PIGENUS_ENV=production
PIGENUS_HOST=127.0.0.1
PIGENUS_PORT=8000
PIGENUS_DATABASE_URL=sqlite:////var/lib/pigenus/pigenus.sqlite3
PIGENUS_ADMIN_TOKEN=replace-with-a-long-random-secret-at-least-24-chars
PIGENUS_TOKEN_PEPPER=replace-with-another-long-random-secret
PIGENUS_LOG_LEVEL=INFO
PIGENUS_ENABLE_SCHEDULER=true
PIGENUS_NIGHTLY_HOUR_UTC=2

